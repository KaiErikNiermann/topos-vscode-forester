{
  "scopeName": "source.forester",
  "patterns": [
    { "include": "#body" }
  ],
  "repository": {
    "body": {
      "patterns": [
        { "include": "#tex-command" },
        { "include": "#tex" },
        { "include": "#verbatim" },
        { "include": "#link" },
        {
          "begin": "(\\\\transclude|\\\\import|\\\\export|\\\\ref)\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "markup.underline.link.forester",
          "beginCaptures": {
            "1": { "name": "constant.language.forester" }
          }
        },
        {
          "begin": "(\\\\em)\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "markup.italic.forester",
          "beginCaptures": {
            "1": { "name": "constant.language.forester" }
          }
        },
        {
          "begin": "(\\\\strong)\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "markup.bold.forester",
          "beginCaptures": {
            "1": { "name": "constant.language.forester" }
          }
        },
        {
          "begin": "(\\\\title)\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "markup.heading.forester",
          "beginCaptures": {
            "1": { "name": "constant.language.forester" }
          }
        },
        {
          "begin": "(\\\\code)\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "markup.inline.raw.forester",
          "beginCaptures": {
            "1": { "name": "constant.language.forester" }
          }
        },
        {
          "begin": "#?#\\{",
          "end": "\\}",
          "patterns": [{ "include": "#body" }],
          "contentName": "meta.math.forester"
        },
        {
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#text" },
            { "include": "#body" }
          ]
        },
        { "include": "#command" },
        { "include": "#comment" }
      ]
    },
    "text": {
      "patterns": [
        {
          "match": "([^%#\\\\\\{\\}\\[\\]\\(\\)\\r\\n]|\\\\%|\\\\\\\\)+",
          "name": "markup.text.forester"
        }
      ]
    },
    "tex": {
      "comment": "\\startverb%tex block with LaTeX highlighting",
      "begin": "(\\\\startverb)(%)(tex).*",
      "end": "\\\\stopverb",
      "patterns": [
        { "include": "text.tex.latex" }
      ],
      "beginCaptures": {
        "1": { "name": "constant.language.forester" },
        "2": { "name": "punctuation.definition.comment.forester comment.line.percentage.forester" },
        "3": { "name": "keyword.other.forester" }
      },
      "endCaptures": {
        "0": { "name": "constant.language.forester" }
      },
      "contentName": "embedded.latex"
    },
    "tex-command": {
      "comment": "\\tex{preamble}{content} - handles both arguments",
      "begin": "(\\\\tex)\\s*(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "constant.language.forester" },
        "2": { "name": "punctuation.definition.group.begin.forester" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.group.end.forester" }
      },
      "patterns": [
        { "include": "#tex-preamble-content" }
      ]
    },
    "tex-preamble-content": {
      "comment": "Content inside \\tex first arg (preamble) with LaTeX highlighting",
      "patterns": [
        { "include": "#tex-nested-brace-latex" },
        { "include": "text.tex.latex" },
        { "include": "#tex-second-arg" }
      ]
    },
    "tex-second-arg": {
      "comment": "Second argument of \\tex - content with possible verbatim",
      "begin": "(\\})\\s*(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.group.end.forester" },
        "2": { "name": "punctuation.definition.group.begin.forester" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.group.end.forester" }
      },
      "patterns": [
        { "include": "#tex-verbatim-block" },
        { "include": "#tex-nested-brace-content" },
        { "include": "text.tex.latex" }
      ],
      "contentName": "meta.embedded.block.latex"
    },
    "tex-nested-brace-latex": {
      "comment": "Nested braces in LaTeX preamble",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#tex-nested-brace-latex" },
        { "include": "text.tex.latex" }
      ]
    },
    "tex-verbatim-block": {
      "comment": "Verbatim block inside \\tex content - no LaTeX highlighting",
      "begin": "\\\\startverb",
      "end": "\\\\stopverb",
      "contentName": "markup.raw.forester",
      "beginCaptures": {
        "0": { "name": "constant.language.forester" }
      },
      "endCaptures": {
        "0": { "name": "constant.language.forester" }
      }
    },
    "tex-nested-brace-content": {
      "comment": "Nested braces in tex content that may contain verbatim",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#tex-verbatim-block" },
        { "include": "#tex-nested-brace-content" },
        { "include": "text.tex.latex" }
      ]
    },
    "verbatim": {
      "begin": "\\\\startverb",
      "end": "\\\\stopverb",
      "contentName": "markup.raw.forester",
      "beginCaptures": {
        "0": { "name": "constant.language.forester" }
      },
      "endCaptures": {
        "0": { "name": "constant.language.forester" }
      }
    },
    "command": {
      "patterns": [
        {
          "match": "\\\\[A-Za-z][0-9A-Za-z\\-/#]*",
          "captures": {
            "0": { "name": "constant.language.forester" }
          }
        },
        {
          "match": "\\\\<([A-Za-z][0-9A-Za-z\\-/#:]*)>",
          "captures": {
            "0": { "name": "constant.language.forester" },
            "1": { "name": "support.variable.xmlns.forester" }
          }
        }
      ]
    },
    "comment": {
      "begin": "%",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.forester"
        }
      },
      "end": "$\\n?",
      "name": "comment.line.percentage.forester"
    },
    "link": {
      "patterns": [
        {
          "match": "\\[([^\\[]*)\\]\\(([^\\)]*)\\)",
          "captures": {
            "1": { "name": "markup.text.forester" },
            "2": { "name": "markup.underline.link.forester" }
          }
        },
        {
          "begin": "\\[\\[",
          "end": "\\]\\]",
          "contentName": "markup.underline.link.forester"
        }
      ]
    }
  }
}
